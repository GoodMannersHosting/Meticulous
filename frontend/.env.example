# Meticulous Frontend Environment Variables

# API Base URL (the backend server)
PUBLIC_API_URL=http://localhost:8080

# WebSocket URL for real-time updates
PUBLIC_WS_URL=ws://localhost:8080/ws

# OAuth/OIDC Configuration
PUBLIC_OIDC_CLIENT_ID=meticulous
PUBLIC_OIDC_AUTHORITY=http://localhost:8080/auth

# Feature Flags
PUBLIC_ENABLE_DARK_MODE=true
