# Meticulous Environment Configuration
# Copy this file to .env and adjust values as needed.

# ============================================================================
# Database (PostgreSQL)
# ============================================================================

# Connection URL (required for sqlx compile-time checks)
DATABASE_URL=postgres://meticulous:meticulous@localhost:5432/meticulous

# Pool settings (optional)
# MET_DATABASE__MAX_CONNECTIONS=10
# MET_DATABASE__MIN_CONNECTIONS=1

# ============================================================================
# HTTP Server
# ============================================================================

# Listen address
# MET_HTTP__LISTEN_ADDR=0.0.0.0:8080

# Public HTTPS base URL of this deployment (OIDC issuer for workload identity, ADR-017).
# Ingress must route `/.well-known/*` to met-api. When unset, the first CORS origin is used (dev only).
# MET_HTTP__PUBLIC_BASE_URL=https://meticulous.example.com

# CORS origins (comma-separated, or use MET_HTTP__CORS_ALLOW_ANY=true for dev)
# MET_HTTP__CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Platform encryption (built-in secrets + OIDC signing keys)
# ============================================================================

# Base64 master key (16+ bytes decoded). Required for stored secrets and for bootstrapping
# OIDC workload signing keys (`/.well-known/jwks.json`). Generate with: openssl rand -base64 32
# MET_BUILTIN_SECRETS_MASTER_KEY=

# ============================================================================
# Authentication
# ============================================================================

# JWT secret key (CHANGE THIS IN PRODUCTION - use 32+ character random string)
MET_JWT__SECRET=development-secret-change-in-production

# JWT expiration time in seconds (default: 3600 = 1 hour)
# MET_JWT__EXPIRATION=3600

# ============================================================================
# met-controller (gRPC) — workload OIDC JWTs (ADR-017)
# ============================================================================
#
# Issuer URL for `iss` on job identity tokens (must match `/.well-known/openid-configuration`).
# Defaults to MET_HTTP__PUBLIC_BASE_URL, then the first CORS origin (dev only).
# MET_CONTROLLER_OIDC_ISSUER_URL=https://meticulous.example.com
#
# Token lifetime in seconds (60–3600). Default 600 (10 minutes) for Vault / Artifactory JWT auth.
# MET_CONTROLLER_OIDC_ID_TOKEN_TTL_SECS=600

# ============================================================================
# NATS Message Broker
# ============================================================================

# NATS server URL
# MET_NATS__URL=nats://localhost:4222

# ============================================================================
# Object Storage (S3-compatible)
# ============================================================================

# SeaweedFS or S3-compatible endpoint
# MET_STORAGE__ENDPOINT=http://localhost:8333
# MET_STORAGE__BUCKET=meticulous

# When ENDPOINT is set (non-AWS), the S3 client does not use your ~/.aws SSO/profile chain.
# Keys are taken in order: storage.access_key/secret_key (here or in config.toml), then
# AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY, then MET_STORAGE__ACCESS_KEY/MET_STORAGE__SECRET_KEY.
# For localhost/127.0.0.1/::1 only, admin/admin is used if none are set.
# MET_STORAGE__ACCESS_KEY=your-access-key
# MET_STORAGE__SECRET_KEY=your-secret-key
# MET_STORAGE__REGION=us-east-1
# MET_STORAGE__AUTO_CREATE_BUCKET=true

# met-api and met-controller both read MET_STORAGE__* (controller archives finished job logs to S3).
# Docker Compose mounts deploy/seaweed/s3-dev.json so Seaweed accepts access key `admin` / secret `admin`.
# After changing S3 config, restart the seaweedfs container.
# The services create MET_STORAGE__BUCKET on startup if it does not exist (same credentials as above).
# Set MET_STORAGE__AUTO_CREATE_BUCKET=false to disable and create the bucket out of band instead.

# ============================================================================
# Logging
# ============================================================================

# Rust log level (RUST_LOG)
RUST_LOG=info,met_api=debug,tower_http=debug

# Structured logging format (text, json, compact)
# MET_LOG__FORMAT=text
